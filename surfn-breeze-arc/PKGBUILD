pkgname=surfn-breeze-arc-icons-git
pkgver=26.06
pkgrel=05
_destname1="/usr/share/icons/"
pkgdesc="Surfn Breeze Arc icon theme"
arch=('any')
url="https://github.com/erikdubois/surfn-breeze-arc"
license=('Attribution-NonCommercial-ShareAlike 4.0 International Public License')
makedepends=('git')
options=(!strip !emptydirs)
depends=('surfn-icons-git')
source=('Surfn::git+https://github.com/erikdubois/surfn-breeze-arc.git')
sha256sums=('SKIP')

package() {
  install -dm 755 ${pkgdir}${_destname1}
  cp -r ${srcdir}/Surfn/${_destname1}* ${pkgdir}${_destname1}
}
