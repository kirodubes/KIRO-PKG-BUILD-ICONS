pkgname=surfn-tela-icons-git
pkgver=26.06
pkgrel=04
_destname1="/usr/share/icons/"
pkgdesc="Surfn Tela icon theme"
arch=('any')
url="https://github.com/erikdubois/surfn-tela"
license=('GPL3')
makedepends=('git')
options=(!strip !emptydirs)
depends=('surfn-icons-git')
source=('Surfn::git+https://github.com/erikdubois/surfn-tela.git')
sha256sums=('SKIP')

package() {
  install -dm 755 ${pkgdir}${_destname1}
  cp -r ${srcdir}/Surfn/${_destname1}* ${pkgdir}${_destname1}
}
