pkgname=surfn-horst-red-icons-git
pkgver=26.06
pkgrel=02
_destname1="/usr/share/icons/"
pkgdesc="Surfn Horst-Red icon theme"
arch=('any')
url="https://github.com/erikdubois/surfn-horst-red"
license=('GPL3')
makedepends=('git')
options=(!strip !emptydirs)
depends=('surfn-icons-git')
source=('Surfn::git+https://github.com/erikdubois/surfn-horst-red.git')
sha256sums=('SKIP')

package() {
  install -dm 755 ${pkgdir}${_destname1}
  cp -r ${srcdir}/Surfn/${_destname1}* ${pkgdir}${_destname1}
}
