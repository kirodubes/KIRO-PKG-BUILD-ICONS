pkgname=neo-candy-mint-x-orange-icons-git
pkgver=26.06
pkgrel=02
_destname1="/usr/share/icons/"
pkgdesc="Neo Candy Mint-X-Orange icon theme (folders)"
arch=('any')
url="https://github.com/erikdubois/neo-candy-mint-x-orange"
license=('GPL3')
makedepends=('git')
options=(!strip !emptydirs)
depends=('neo-candy-icons-git')
source=('NeoCandy::git+https://github.com/erikdubois/neo-candy-mint-x-orange.git')
sha256sums=('SKIP')

package() {
  install -dm 755 ${pkgdir}${_destname1}
  cp -r ${srcdir}/NeoCandy/${_destname1}* ${pkgdir}${_destname1}
}
