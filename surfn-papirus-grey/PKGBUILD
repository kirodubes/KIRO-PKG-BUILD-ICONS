pkgname=surfn-papirus-grey-icons-git
pkgver=26.06
pkgrel=04
_destname1="/usr/share/icons/"
pkgdesc="Surfn Papirus Grey folder colour theme"
arch=('any')
url="https://github.com/erikdubois/surfn-papirus-grey"
license=('GPL3')
makedepends=('git')
options=(!strip !emptydirs)
depends=('surfn-icons-git')
source=('Source::git+https://github.com/erikdubois/surfn-papirus-grey.git')
sha256sums=('SKIP')

package() {
  install -dm 755 ${pkgdir}${_destname1}
  cp -r ${srcdir}/Source/${_destname1}* ${pkgdir}${_destname1}
}
