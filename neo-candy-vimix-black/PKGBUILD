pkgname=neo-candy-vimix-black-icons-git
pkgver=26.06
pkgrel=03
_destname1="/usr/share/icons/"
pkgdesc="Neo Candy Vimix Black icon theme (folders)"
arch=('any')
url="https://github.com/erikdubois/neo-candy-vimix-black"
license=('Attribution-NonCommercial-ShareAlike 4.0 International Public License')
makedepends=('git')
options=(!strip !emptydirs)
depends=('neo-candy-icons-git')
source=('NeoCandy::git+https://github.com/erikdubois/neo-candy-vimix-black.git')
sha256sums=('SKIP')

package() {
  install -dm 755 ${pkgdir}${_destname1}
  cp -r ${srcdir}/NeoCandy/${_destname1}* ${pkgdir}${_destname1}
}
